# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Agente IA ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── JWT (tokens de paciente OTP) ──────────────────────────────────────────────
JWT_SECRET=cambiar-en-produccion

# ── FastAPI ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── WhatsApp del consultorio ──────────────────────────────────────────────────
# Formato 549XXXXXXXXXX sin + ni espacios
WA_NUMBER=5491100000000

# ── Encriptación de datos sensibles (Fernet AES-128 + HMAC-SHA256) ────────────
# Generar nueva clave:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRÍTICO: si se pierde esta clave, los datos encriptados son irrecuperables.
# Backupear fuera del VPS (password manager, etc).
ENCRYPTION_KEY=

# Sal para hashes determinísticos de búsqueda (teléfonos, OTPs).
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
HASH_SALT=

# Si true, el backend al arrancar encripta registros aún en plano (idempotente).
# Se puede desactivar después del primer arranque exitoso.
RUN_ENCRYPTION_BACKFILL=true

# ── Cron externo (GitHub Actions, etc) ────────────────────────────────────────
# Token compartido entre el backend y el caller del cron (header X-Cron-Token).
# Generar:
#   openssl rand -hex 32
# El MISMO valor debe configurarse como secret CRON_TOKEN en GitHub Actions.
CRON_TOKEN=
