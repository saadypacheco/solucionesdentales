# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── WhatsApp del consultorio (default si no viene del backend) ────────────────
NEXT_PUBLIC_WA_NUMBER=5491100000000

# ── Multi-tenant (M13 Fase 5a) ────────────────────────────────────────────────
# ID del consultorio para endpoints públicos (turnos, casos, agente, OTP).
# Cada deploy del frontend = 1 consultorio. El backend lee este header
# (X-Consultorio-ID) para filtrar la data del consultorio correcto.
# Si no se setea, usa 1 (consultorio "Soluciones Dentales (default)").
NEXT_PUBLIC_CONSULTORIO_ID=1

# ── Server-side: proxy Next.js → backend FastAPI ──────────────────────────────
# El browser nunca ve esta URL (no es NEXT_PUBLIC_), Vercel proxea sin mixed-content
API_URL=http://localhost:8001
